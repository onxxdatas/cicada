# Absolute path to this project directory ON THE HOST.
# Required because the backend asks the HOST docker daemon to mount ./data
# into the k6 containers it spawns - the daemon only understands host paths.
#
# Linux/macOS: run `pwd` inside this folder and paste the result.
# Example: HOST_PROJECT_DIR=/home/abdulaziz/Desktop/cicada
HOST_PROJECT_DIR=/absolute/path/to/cicada

# Postgres
POSTGRES_USER=cicada
POSTGRES_PASSWORD=cicada
POSTGRES_DB=cicada
DATABASE_URL=postgresql+psycopg2://cicada:cicada@postgres:5432/cicada

# Database Connection Pool
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# Redis (reserved for future use: run queueing / caching)
REDIS_URL=redis://redis:6379/0

# k6
K6_IMAGE=grafana/k6:latest

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
